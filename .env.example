# Copy to .env and adjust. All keys are optional; env vars override settings.yaml.

# Path to the global settings.yaml (default: ./config/settings.yaml)
# PDFSCAN_CONFIG=C:\path\to\settings.yaml

# Override the SQLite database path (default: ./data/pdfscan.db)
# PDFSCAN_DB_PATH=C:\path\to\pdfscan.db

# Explicit path to the veraPDF executable (default: auto-downloaded app-data location)
# PDFSCAN_VERAPDF=C:\path\to\verapdf.bat

# Where downloaded PDFs are saved for remediation (default: ./remediation)
# PDFSCAN_STORAGE_ROOT=C:\path\to\remediation

# --- Scan sessions (relocatable, named output workspaces) --------------------
# A session relocates ALL outputs (db/exports/remediation/scratch) under one
# folder. Manage them with `pdfscan session ...`. These vars override the active
# session for a run (an explicit --output-root / PDFSCAN_OUTPUT_ROOT still wins):
# PDFSCAN_SESSION=sonoma-2026                 # use a registered session by name
# PDFSCAN_SESSION_ROOT=D:\pdfscan-data\adhoc  # use an ad-hoc workspace root (no registration)
# Where the session registry lives (default: %APPDATA%\pdfscan\sessions.yaml on
# Windows, ${XDG_CONFIG_HOME:-~/.config}/pdfscan/sessions.yaml elsewhere):
# PDFSCAN_SESSIONS_FILE=C:\path\to\sessions.yaml
